# ─────────────────────────────────────────
# QuantLux Environment Configuration
# ─────────────────────────────────────────

# ── Core ─────────────────────────────────
TRADING_ENV=development
LOG_LEVEL=INFO
LOG_TO_FILE=true

# ── MetaApi (REQUIRED) ───────────────────
METAAPI_TOKEN=your_metaapi_token_here
METAAPI_ACCOUNT_ID=your_account_id_here
METAAPI_REGION=new-york

# ── Telegram (OPTIONAL) ──────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ── AI / Gemini (OPTIONAL) ───────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Trading Logic & Risk ─────────────────
ENABLE_AUTO_TRADING=false
ENABLE_NEWS_FILTER=true
ENABLE_AI_FEATURES=true
ENABLE_AI_RISK_GUARD=true
ALLOW_SPLIT_EXECUTION=false
EMERGENCY_CLOSE_ON_SHUTDOWN=true
USE_RSI_STRATEGY=true

MAX_DAILY_DRAWDOWN_PCT=5.0
MAX_TOTAL_DRAWDOWN_PCT=15.0
PER_TRADE_RISK_PCT=1.0
DEFAULT_LOT_SIZE=0.01
MAX_OPEN_TRADES=5
MAX_POSITIONS_PER_SYMBOL=1
MAGIC_NUMBER=123456
DEFAULT_INITIAL_BALANCE=10000.0
RISK_FREE_RATE=0.02

# Stop Loss & Spread
DEFAULT_SL_PIPS=20
MAX_SLIPPAGE=3.0
MAX_SPREAD_PIPS=5.0
MIN_MARGIN_LEVEL=100.0

# ── News Filter ───────────────────────────
FOREXFACTORY_BASE_URL=https://www.forexfactory.com/calendar?day={}
NEWS_IMPACT_FILTER=["High","Medium"]
NEWS_PAUSE_MINUTES_BEFORE=30
NEWS_PAUSE_MINUTES_AFTER=30

# ── Connectivity & Intervals ──────────────
FEED_POLL_INTERVAL=1
FEED_ERROR_INTERVAL=5
MT5_RECONNECT_INTERVAL=10
WS_HEALTH_CHECK_INTERVAL=30
WS_HEALTH_TIMEOUT=10
WS_MAX_RECONNECT_ATTEMPTS=5
WS_RECONNECT_DELAY=5

# ── Infrastructure ────────────────────────
REDIS_URL=redis://redis:6379/0
